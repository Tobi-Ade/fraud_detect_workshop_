{
  "aws": {
    "region": "us-east-1",
    "sagemaker_role": "arn:aws:iam::ACCOUNT_ID:role/SageMakerExecutionRole",
    "s3_bucket": "fraud-detection-workshop-TIMESTAMP"
  },
  "training": {
    "instance_type": "ml.m5.xlarge",
    "instance_count": 1,
    "max_runtime_seconds": 3600,
    "hyperparameters": {
      "n_estimators": 100,
      "max_depth": 6,
      "learning_rate": 0.1,
      "random_state": 42
    }
  },
  "deployment": {
    "instance_type": "ml.t2.medium",
    "initial_instance_count": 1,
    "endpoint_name": "fraud-detection-endpoint"
  },
  "data": {
    "dataset_url": "https://storage.googleapis.com/download.tensorflow.org/data/creditcard.csv",
    "sampling_strategy": 0.3,
    "test_size": 0.2
  }
}
